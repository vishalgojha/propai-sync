// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

PROPAI_CODE_SIGN_STYLE = Automatic
PROPAI_DEVELOPMENT_TEAM = YOUR_TEAM_ID

PROPAI_APP_BUNDLE_ID = ai.propai.client
PROPAI_SHARE_BUNDLE_ID = ai.propai.client.share
PROPAI_ACTIVITY_WIDGET_BUNDLE_ID = ai.propai.client.activitywidget
PROPAI_WATCH_APP_BUNDLE_ID = ai.propai.client.watchkitapp
PROPAI_WATCH_EXTENSION_BUNDLE_ID = ai.propai.client.watchkitapp.extension

// Leave empty with automatic signing.
PROPAI_APP_PROFILE =
PROPAI_SHARE_PROFILE =



