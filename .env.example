# PropAiSync .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.PropAiSync/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.PropAiSync/.env, then PropAiSync.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in PropAiSync.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
PROPAI_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# PROPAI_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# PROPAI_STATE_DIR=~/.PropAiSync
# PROPAI_CONFIG_PATH=~/.propai/propai.json
# PROPAI_HOME=~

# Optional: import missing keys from your login shell profile.
# PROPAI_LOAD_SHELL_ENV=1
# PROPAI_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# PROPAI_LIVE_OPENAI_KEY=sk-...
# PROPAI_LIVE_ANTHROPIC_KEY=sk-ant-...
# PROPAI_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2
# GROQ_API_KEY=...
# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# ELEVENLABS_AGENT_ID=...  # required for ElevenLabs Conversational AI

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# WhatsApp Cloud API (hosted)
# META_WA_ACCESS_TOKEN=...
# META_WA_PHONE_NUMBER_ID=...
# META_WA_VERIFY_TOKEN=...
# META_WA_APP_SECRET=...
# META_WA_BASE_URL=https://graph.facebook.com/v21.0

# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# PROPAI_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Control UI (hosted)
# -----------------------------------------------------------------------------
# PROPAI_CONTROL_UI_ALLOWED_ORIGINS=https://app.propai.live
# PROPAI_CONTROL_UI_HOST_HEADER_FALLBACK=true

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Control API (hosted multi-tenant)
# -----------------------------------------------------------------------------
# CONTROL_JWT_SECRET=change-me-to-a-long-random-secret
# CONTROL_DB_PATH=./.data/control.sqlite
# CONTROL_ADMIN_KEY=change-me-for-admin-tenant-creation
# CONTROL_JWT_TTL_DAYS=30
# CONTROL_INVITE_TTL_DAYS=7
# CONTROL_USAGE_INGEST_KEY=change-me-to-a-long-random-secret
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gateway -> Control API usage reporting
# CONTROL_API_URL=http://localhost:8788
# CONTROL_TENANT_ID=tnt_...



