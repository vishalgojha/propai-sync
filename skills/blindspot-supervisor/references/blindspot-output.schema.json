{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/blindspot-supervisor/blindspot-output.schema.json",
  "title": "BlindspotSupervisorOutput",
  "description": "Structured form equivalent of the required four-part blind-spot response.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "misses",
    "why_it_matters",
    "background",
    "suggested_fix"
  ],
  "properties": {
    "misses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "issue",
          "severity",
          "confidence",
          "evidence"
        ],
        "properties": {
          "issue": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/evidence_item"
            }
          }
        }
      }
    },
    "why_it_matters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "background": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "suggested_fix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "file",
            "command",
            "tool_output",
            "inference"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    }
  }
}
