{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/blindspot-supervisor/evidence-item.schema.json",
  "title": "BlindspotEvidenceItem",
  "description": "Single evidence anchor attached to a blind-spot finding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "value"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "file",
        "command",
        "tool_output",
        "inference"
      ]
    },
    "value": {
      "type": "string",
      "minLength": 1
    },
    "note": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
